#!/bin/bash
# Pre-commit hook: block sensitive files, then check for vulnerabilities.
# Install: ln -sf ../../scripts/pre-commit .git/hooks/pre-commit
set -euo pipefail

export PATH="$HOME/.local/go/bin:$HOME/go/bin:/usr/local/go/bin:/usr/local/bin:$PATH"

# --- Guard: block sensitive files from being committed ---
BLOCKED_PATTERNS=(
  'PLAN.md'
  'NOTES.md'
  'DRAFT.md'
  'PRIVATE.md'
  'INTERNAL.md'
  '.env'
  '.env.'
  '*.pem'
  '*.key'
  '*.p12'
  '*.pfx'
  'credentials.json'
  '*.htpasswd'
  '.DS_Store'
  'Thumbs.db'
)

staged=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)
for file in $staged; do
  basename=$(basename "$file")
  for pattern in "${BLOCKED_PATTERNS[@]}"; do
    if [[ "$basename" == $pattern ]]; then
      echo "BLOCKED: '$file' matches sensitive pattern '$pattern'"
      echo "If this is a false positive, use: git add -f <file> (not recommended for secrets)"
      exit 1
    fi
  done
  # Check file content for private keys
  if git show ":$file" 2>/dev/null | grep -qE 'BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY'; then
    echo "BLOCKED: '$file' contains a private key"
    exit 1
  fi
done

echo "==> Sensitive file guard: passed"

echo "==> Sensitive content scan"
bash scripts/check-sensitive-content

# --- go vet ---
echo "==> go vet ./..."
go vet ./... || { echo "FAIL: go vet found issues. Fix them before committing."; exit 1; }

echo "==> govulncheck ./..."
if command -v govulncheck &>/dev/null; then
    output=$(govulncheck -C 0 ./... 2>&1) || true
    if echo "$output" | grep -q "Your code is affected by"; then
        echo "FAIL: govulncheck found vulnerabilities. Upgrade affected packages before committing."
        echo "$output"
        exit 1
    fi
    echo "govulncheck: clean"
else
    echo "WARNING: govulncheck not installed. Run: go install golang.org/x/vuln/cmd/govulncheck@latest"
fi

echo "==> go mod tidy"
go mod tidy
if ! git diff --quiet go.mod go.sum; then
    echo "FAIL: go.mod/go.sum are not tidy. Run 'go mod tidy' before committing."
    git diff go.mod go.sum
    exit 1
fi

echo "All checks passed."
