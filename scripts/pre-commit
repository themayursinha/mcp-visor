#!/bin/bash
# Pre-commit hook: block commits with known vulnerabilities or vet failures.
# Install: ln -sf ../../scripts/pre-commit .git/hooks/pre-commit
set -euo pipefail

export PATH="$HOME/.local/go/bin:$HOME/go/bin:/usr/local/go/bin:/usr/local/bin:$PATH"

echo "==> go vet ./..."
go vet ./... || { echo "FAIL: go vet found issues. Fix them before committing."; exit 1; }

echo "==> govulncheck ./..."
if command -v govulncheck &>/dev/null; then
    output=$(govulncheck -C 0 ./... 2>&1) || true
    if echo "$output" | grep -q "Your code is affected by"; then
        echo "FAIL: govulncheck found vulnerabilities. Upgrade affected packages before committing."
        echo "$output"
        exit 1
    fi
    echo "govulncheck: clean"
else
    echo "WARNING: govulncheck not installed. Run: go install golang.org/x/vuln/cmd/govulncheck@latest"
fi

echo "==> go mod tidy"
go mod tidy
if ! git diff --quiet go.mod go.sum; then
    echo "FAIL: go.mod/go.sum are not tidy. Run 'go mod tidy' before committing."
    git diff go.mod go.sum
    exit 1
fi

echo "All checks passed."
